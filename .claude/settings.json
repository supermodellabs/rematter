{
	"permissions": {
		"allow": ["Bash(uv run *)", "Bash(uv sync *)", "Read(~/.cache/uv/**)"]
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": false,
		"allowUnsandboxedCommands": false,
		"filesystem": {
			"allowWrite": ["~/.cache/uv/**"]
		},
		"network": {
			"allowedDomains": ["docs.astral.sh", "pypi.org", "pythonhosted.org"],
			"allowLocalBinding": true
		}
	}
}
